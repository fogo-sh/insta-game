{
  "id": "ioquake3",
  "displayName": "ioquake3 (Quake 3 Arena)",
  "protocol": "quake3",
  "sidecarPort": 5001,
  "gamePort": 27960,
  "ports": {
    "27960/udp": {
      "hostPort": "27960"
    },
    "5001/tcp": {
      "hostPort": "5006"
    }
  },
  "gameCmd": "./ioq3ded",
  "gameArgs": "+set dedicated 2 +set fs_basepath /opt +set fs_homepath /opt +set net_ip 0.0.0.0 +set net_port 27960 +set sv_maxclients 8 +set com_hunkMegs 64 +exec server.cfg",
  "gameQuitCmd": "quit",
  "gameQuitTimeout": 15,
  "configPath": "/opt/baseq3/server.cfg",
  "volumes": [
    ".cache/ioquake3:/opt/baseq3"
  ],
  "dataUrlEnv": "IOQUAKE3_DATA_URL",
  "clientDownloadUrl": "https://ioquake3.org/get-it/"
}
